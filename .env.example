# ── GRS Safety — environment ──────────────────────────────
# Railway injects DATABASE_URL and PORT automatically when you
# add a Postgres plugin. Locally, set DATABASE_URL yourself.

DATABASE_URL=postgres://user:pass@localhost:5432/grs_safety
NODE_ENV=development

# REQUIRED in production — a long random string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# Optional: set these before running `npm run seed` to choose
# the two consultant logins and their initial passwords.
SEED_USER1_EMAIL=dec@safety-simplified.com
SEED_USER1_PASS=
SEED_USER2_EMAIL=frank@safety-simplified.com
SEED_USER2_PASS=
